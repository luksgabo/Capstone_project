% Outer theme for dscapstonetemplatecoursera
\mode<presentation>

\usepackage{etoolbox}
\RequirePackage{tikz}
\usetikzlibrary{positioning}

% Remove navigation symbols
\setbeamertemplate{navigation symbols}{}

% Default Frame title
\setbeamertemplate{frametitle}{%
  \vspace{0.5cm}
  \hspace{1em}{\usebeamerfont{frametitle}\insertframetitle}
  \vspace{0.2cm}
}

% --- Slide Layout Environments ---
\newenvironment{titleslide}{%
  % ACTIVATE the correct templates for this layout
  \setbeamertemplate{frametitle}[titleslide]
  \setbeamertemplate{framesubtitle}[titleslide]
  % Original code follows
  \usebackgroundtemplate{}
  \setbeamercolor{frametitle}{fg=ppttx2}
  \setbeamercolor{item}{fg=ppttx2}
}{%
  % End of layout environment
}

% Custom frametitle template for Title Slide
\defbeamertemplate{frametitle}{titleslide}{%
  \begin{tikzpicture}[remember picture, overlay]
  \end{tikzpicture}
}

% Custom framesubtitle template for Title Slide (now integrated above)
\defbeamertemplate{framesubtitle}{titleslide}{%
  % This template is now integrated into the frametitle template above
}


